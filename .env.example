# ─────────────────────────────────────────────────────────────────────────────
# geminispecwebapp — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git (it's in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="Cliente Agéntico Universal Framework 2050"
VITE_APP_URL=http://localhost:5173
# v2.0: VITE_APP_URL=https://geminispecwebapp.thelaunchpadtlp.education

# ─── Google Gemini AI (v2.0) ──────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=gemini-2.0-flash

# ─── Cloudinary Media (v2.0) ─────────────────────────────────────────────────
# Create account at: https://cloudinary.com
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_UPLOAD_PRESET=geminispecwebapp

# ─── Firebase / GCP (v2.0) ───────────────────────────────────────────────────
# Get from Firebase Console: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Backend API (v2.0) ───────────────────────────────────────────────────────
# Cloud Run or Cloud Functions URL
VITE_API_BASE_URL=

# ─── GitHub (for GodApp live data, v2.0) ─────────────────────────────────────
# Personal Access Token with repo:read scope (for live commit history in GodApp)
VITE_GITHUB_TOKEN=
VITE_GITHUB_REPO=thelaunchpadtlp/geminispecwebapp

# ─── Analytics (v2.0) ────────────────────────────────────────────────────────
VITE_GA4_MEASUREMENT_ID=
